{
  "title": "OpenManus",
  "timezone": "browser",
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "Request rate",
      "type": "timeseries",
      "targets": [
        {"expr": "rate(openmanus_requests_total[5m])", "legendFormat": "{{method}} {{path}} {{status}}"}
      ]
    },
    {
      "id": 2,
      "title": "Request latency p95",
      "type": "timeseries",
      "targets": [
        {"expr": "histogram_quantile(0.95, rate(openmanus_request_latency_seconds_bucket[5m]))", "legendFormat": "p95"}
      ]
    },
    {
      "id": 3,
      "title": "Memory (RSS bytes)",
      "type": "timeseries",
      "targets": [{"expr": "openmanus_memory_usage_bytes", "legendFormat": "rss"}]
    },
    {
      "id": 4,
      "title": "CPU percent",
      "type": "timeseries",
      "targets": [{"expr": "openmanus_cpu_usage_percent", "legendFormat": "cpu"}]
    }
  ]
}
